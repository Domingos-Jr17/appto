{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "tailwindcss-server": {
      "type": "local",
      "command": ["npx", "-y", "tailwindcss-mcp-server"],
      "enabled": true
    }
  }
}