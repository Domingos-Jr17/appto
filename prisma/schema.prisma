// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

// ==================== USER & AUTH ====================

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  password        String?   // Hashed password for credentials auth
  image           String?
  emailVerified   DateTime?
  role            Role            @default(STUDENT)
  educationLevel  EducationLevel? @default(SECONDARY)
  twoFactorEnabled Boolean        @default(false)
  passwordChangedAt DateTime?
  failedLoginAttempts Int         @default(0)
  lockoutUntil     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  projects        Project[]
  credits         Credit?
  transactions    CreditTransaction[]
  subscription    Subscription?
  settings        UserSettings?
  passwordResetTokens PasswordResetToken[]
  authSessionAudits AuthSessionAudit[]
  totpCredential  TotpCredential?
  recoveryCodes   RecoveryCode[]
  paymentTransactions PaymentTransaction[]
  workPurchases       WorkPurchase[]
  knowledgeSources KnowledgeSource[]
  storedFiles     StoredFile[]
  createdExports  ProjectExport[]     @relation("ProjectExportCreator")
  generationJobs  GenerationJob[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model AuthSessionAudit {
  id         String           @id @default(cuid())
  userId     String
  sessionId  String?
  event      AuthSessionEvent
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("auth_session_audits")
}

model TotpCredential {
  id              String   @id @default(cuid())
  userId          String   @unique
  secretEncrypted String
  enabledAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("totp_credentials")
}

model RecoveryCode {
  id         String   @id @default(cuid())
  userId     String
  codeHash   String   @unique
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("recovery_codes")
}

enum Role {
  STUDENT
  RESEARCHER
  ADMIN
}

enum EducationLevel {
  SECONDARY        // Ensino Secundário
  TECHNICAL        // Ensino Técnico Profissional
  HIGHER_EDUCATION // Ensino Superior
}

// ==================== PROJECTS & DOCUMENTS ====================

model Project {
  id              String         @id @default(cuid())
  title           String
  description     String?
  type            ProjectType    @default(MONOGRAPHY)
  educationLevel  EducationLevel @default(SECONDARY)
  status          ProjectStatus  @default(DRAFT)
  wordCount       Int            @default(0)
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  brief           ProjectBrief?
  sections        DocumentSection[]
  storedFiles     StoredFile[]
  exports         ProjectExport[]
  generationJob   GenerationJob?

  @@map("projects")
}

model ProjectBrief {
  projectId               String               @id
  workType                ProjectType
  generationStatus        WorkGenerationStatus @default(BRIEFING)
  institutionName         String?
  courseName              String?
  subjectName             String?
  educationLevel          EducationLevel?
  advisorName             String?
  studentName             String?
  city                    String?
  academicYear            Int?
  dueDate                 DateTime?            @db.Date
  theme                   String?
  subtitle                String?
  objective               String?
  researchQuestion        String?
  methodology             String?
  keywords                String?
  referencesSeed          String?
  citationStyle           CitationStyle        @default(ABNT)
  language                String               @default("pt-MZ")
  additionalInstructions  String?
  coverTemplate           String?              @default("UEM_STANDARD")
  // Education-level specific fields
  className               String?              @db.VarChar(30)   // 10ª/11ª/12ª Classe (Secundário)
  turma                   String?              @db.VarChar(10)   // A/B/C (Secundário)
  facultyName             String?              @db.VarChar(180)  // Faculdade (Superior)
  departmentName          String?              @db.VarChar(180)  // Departamento (Superior)
  studentNumber           String?              @db.VarChar(30)   // Nº de Estudante
  semester                String?              @db.VarChar(10)   // I/II (Superior)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  project                 Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([generationStatus])
  @@map("project_briefs")
}

model GenerationJob {
  id            String   @id @default(cuid())
  projectId     String   @unique
  userId        String
  status        String   @default("GENERATING")
  progress      Int      @default(0)
  step          String?
  error         String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("generation_jobs")
}

model DocumentSection {
  id          String   @id @default(cuid())
  projectId   String
  parentId    String?
  title       String
  content     String?
  order       Int      @default(0)
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      DocumentSection?  @relation("SectionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    DocumentSection[] @relation("SectionTree")

  @@map("document_sections")
}

enum ProjectType {
  // Ensino Superior
  MONOGRAPHY
  DISSERTATION
  THESIS
  ARTICLE
  ESSAY
  REPORT
  
  // Ensino Secundário e Técnico Profissional
  SCHOOL_WORK       // Trabalho Escolar (Secundário)
  RESEARCH_PROJECT  // Projecto de Investigação (Secundário)
  INTERNSHIP_REPORT // Relatório de Estágio (Técnico Profissional)
  PRACTICAL_WORK    // Trabalho Prático (Técnico Profissional)
  TCC               // Trabalho de Conclusão de Curso (Técnico/Secundário)
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  COMPLETED
  ARCHIVED
}

enum WorkGenerationStatus {
  BRIEFING
  GENERATING
  READY
  NEEDS_REVIEW
  FAILED
}

enum CitationStyle {
  ABNT
  APA
  Vancouver
}

// ==================== CREDITS & SUBSCRIPTIONS ====================

model Credit {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  used      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credits")
}

model CreditTransaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Int
  type        TransactionType
  description String?
  metadata    String? // JSON string for additional data
  createdAt   DateTime        @default(now())

  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

model PaymentTransaction {
  id                String          @id @default(cuid())
  userId            String
  provider          PaymentProvider
  providerReference String
  status            PaymentStatus   @default(PENDING)
  creditsAmount     Int
  moneyAmount       Int
  currency          String          @default("MZN")
  payloadJson       Json?
  confirmedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerReference])
  @@index([userId, status, createdAt])
  @@map("payment_transactions")
}

enum TransactionType {
  PURCHASE
  USAGE
  BONUS
  REFUND
  SUBSCRIPTION
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  package         PackageType        @default(FREE)
  status          SubscriptionStatus @default(ACTIVE)
  worksPerMonth   Int                @default(1)
  worksUsed       Int                @default(0)
  lastUsageReset  DateTime           @default(now())
  startDate       DateTime           @default(now())
  endDate         DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model WorkPurchase {
  id            String    @id @default(cuid())
  userId        String
  quantity      Int
  pricePaid     Int
  used          Int       @default(0)
  createdAt     DateTime  @default(now())
  expiresAt     DateTime?
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("work_purchases")
}

enum PackageType {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum AuthSessionEvent {
  SIGN_IN
  SIGN_OUT
  SESSION_REVOKED
  PASSWORD_RESET
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  PASSWORD_CHANGED
}

enum PaymentProvider {
  SIMULATED
  MPESA
  EMOLA
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum StorageProvider {
  LOCAL
  R2
}

enum StoredFileKind {
  AVATAR
  EXPORT
  UPLOAD
  KNOWLEDGE_SOURCE
  ATTACHMENT
}

enum StoredFileStatus {
  PENDING
  READY
  FAILED
  DELETED
}

// ==================== USER SETTINGS ====================

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  language              String   @default("pt-MZ")
  citationStyle         String   @default("ABNT")
  fontSize              Int      @default(14)
  autoSave              Boolean  @default(true)
  aiSuggestionsEnabled  Boolean  @default(true)
  emailNotifications    Boolean  @default(true)
  marketingEmails       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model ProductEvent {
  id         String   @id @default(cuid())
  name       String
  category   String
  userId     String?
  projectId  String?
  paymentId  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([name, createdAt])
  @@index([category, createdAt])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@map("product_events")
}

model KnowledgeSource {
  id          String              @id @default(cuid())
  userId      String?
  name        String
  slug        String              @unique
  type        KnowledgeSourceType
  isActive    Boolean             @default(true)
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   KnowledgeDocument[]

  @@map("knowledge_sources")
}

model KnowledgeDocument {
  id          String            @id @default(cuid())
  sourceId    String
  title       String
  content     String
  metadata    Json?
  checksum    String?
  isIndexed   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  source      KnowledgeSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks      KnowledgeChunk[]

  @@index([sourceId, isIndexed])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id            String            @id @default(cuid())
  documentId    String
  chunkIndex    Int
  content       String
  embeddingJson String?
  embeddingVector Unsupported("vector(128)")? @map("embedding_vector")
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  document      KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@map("knowledge_chunks")
}

enum KnowledgeSourceType {
  PUBLIC
  INSTITUTIONAL
  PRIVATE
}

model StoredFile {
  id           String           @id @default(cuid())
  userId       String
  projectId    String?
  kind         StoredFileKind
  provider     StorageProvider
  bucket       String
  objectKey    String           @unique
  mimeType     String
  sizeBytes    Int
  originalName String
  checksum     String?
  status       StoredFileStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  exports      ProjectExport[]

  @@index([userId, kind, createdAt])
  @@index([projectId, kind, createdAt])
  @@map("stored_files")
}

model ProjectExport {
  id          String       @id @default(cuid())
  projectId   String
  fileId      String
  format      ExportFormat
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        StoredFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("ProjectExportCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId, format, createdAt])
  @@index([createdById, createdAt])
  @@map("project_exports")
}

enum ExportFormat {
  DOCX
  PDF
}
